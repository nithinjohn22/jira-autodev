{
  "mcpServers": {
    "atlassian": {
      "command": "npx",
      "args": ["-y", "@atlassian/mcp-atlassian"],
      "env": {
        "ATLASSIAN_SITE_NAME": "<YOUR_SITE>.atlassian.net",
        "ATLASSIAN_USER_EMAIL": "<YOUR_EMAIL>",
        "ATLASSIAN_API_TOKEN": "${ATLASSIAN_API_TOKEN}"
      }
    }
  }
}
