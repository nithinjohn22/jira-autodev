{
    "name": "nithinjohn22/jira-code-agent",
    "description": "Jira-triggered Claude Code agent — auto-implements tickets and opens draft PRs",
    "type": "project",
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "php -l src/ && php -l tests/"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
